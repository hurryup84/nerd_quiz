generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id            Int                 @id @default(autoincrement())
  username      String              @unique
  passwordHash  String
  role          String              @default("USER")
  createdAt     DateTime            @default(now())
  quizRounds    QuizRound[]
  answers       Answer[]
  finalizations RoundFinalization[]
  teams         UserTeam[]
  createdTeams  Team[]
  sentInvites   TeamInvite[]        @relation("Inviter")
  receivedInvites TeamInvite[]      @relation("Invitee")
  createdQuestions Question[]       @relation("QuestionCreator")

  @@index([username])
}

model Question {
  id            Int             @id @default(autoincrement())
  questionId    String          @unique
  questionText  String
  categoryId    Int?
  difficultyId  Int?
  info          String?
  answerA       String
  answerB       String
  answerC       String
  answerD       String
  correctAnswer String
  playCount     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  creatorId     Int?
  aiAssisted    Boolean         @default(false)
  category      Category?       @relation(fields: [categoryId], references: [id])
  difficulty    Difficulty?     @relation(fields: [difficultyId], references: [id])
  creator         User?           @relation("QuestionCreator", fields: [creatorId], references: [id])
  roundQuestions RoundQuestion[]

  @@index([questionId])
  @@index([categoryId])
  @@index([difficultyId])
  @@index([playCount])
  @@index([creatorId])
}

model Category {
  id                 Int                      @id @default(autoincrement())
  name               String                   @unique
  createdAt          DateTime                 @default(now())
  questions          Question[]
  excludedByTeams    TeamExcludedCategory[]

  @@index([name])
}

model Difficulty {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  questions Question[]

  @@index([name])
}

model QuizRound {
  id                   Int                 @id @default(autoincrement())
  requiredParticipants Int
  status               String              @default("ACTIVE")
  createdBy            User                @relation(fields: [createdById], references: [id])
  createdById          Int
  teamId               String?
  team                 Team?               @relation(fields: [teamId], references: [id])
  createdAt            DateTime            @default(now())
  finishedAt           DateTime?
  timeoutAt            DateTime?
  questions            RoundQuestion[]
  answers              Answer[]
  finalizations        RoundFinalization[]

  @@index([status])
  @@index([status, teamId])
}

model RoundQuestion {
  id          Int       @id @default(autoincrement())
  quizRound   QuizRound @relation(fields: [quizRoundId], references: [id])
  quizRoundId Int
  question    Question  @relation(fields: [questionId], references: [id])
  questionId  Int
  order       Int       
  
  answers     Answer[]
  
  @@unique([quizRoundId, questionId])
  @@index([quizRoundId])
}

model Settings {
  key   String @id
  value String
}

model Answer {
  id              Int           @id @default(autoincrement())
  quizRound       QuizRound     @relation(fields: [quizRoundId], references: [id])
  quizRoundId     Int
  roundQuestion   RoundQuestion @relation(fields: [roundQuestionId], references: [id])
  roundQuestionId Int
  user            User          @relation(fields: [userId], references: [id])
  userId          Int
  selectedAnswer  String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([userId, roundQuestionId])
  @@index([quizRoundId])
  @@index([userId])
}

model RoundFinalization {
  id          Int       @id @default(autoincrement())
  quizRound   QuizRound @relation(fields: [quizRoundId], references: [id])
  quizRoundId Int
  user        User      @relation(fields: [userId], references: [id])
  userId      Int
  createdAt   DateTime  @default(now())

  @@unique([quizRoundId, userId])
}

model Team {
  id                     String                 @id @default(uuid())
  name                   String
  description            String?
  creatorId              Int
  creator                User                   @relation(fields: [creatorId], references: [id])
  members                UserTeam[]
  invites                TeamInvite[]
  rounds                 QuizRound[]
  excludedCategories     TeamExcludedCategory[]
  createdAt              DateTime                @default(now())
}

model TeamExcludedCategory {
  id        Int    @id @default(autoincrement())
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId Int

  @@unique([teamId, categoryId])
}

model UserTeam {
  userId Int
  teamId String
  role   String

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

model TeamInvite {
  id        Int      @id @default(autoincrement())
  teamId    String
  inviterId Int
  inviteeId Int
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  team    Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter User @relation("Inviter", fields: [inviterId], references: [id])
  invitee User @relation("Invitee", fields: [inviteeId], references: [id])

  @@unique([teamId, inviteeId])
}
